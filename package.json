    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^27.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.2",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
